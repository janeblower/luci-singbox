config fakeip 'fakeip'
	option enabled '0'
	list inet4_range '198.18.0.0/15'
	list inet6_range 'fc00::/18'

config tproxy 'tproxy'
	option enabled '0'
	option interface 'br-lan'
	option port '7893'

config ruleset 'geosite_cn'
	option enabled '0'
	option type 'remote'
	option url 'https://cdn.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-cn.srs'
	option format 'binary'
	option dns_fakeip '0'
	option dns_fakeip_tag 'fakeip'
	option nft_rules '0'
	option update_interval '86400'

config route_rule 'cn_to_direct'
	option enabled '0'
	list ruleset 'geosite_cn'
	option action 'direct'

config route_default 'route_default'
	option action 'direct'
