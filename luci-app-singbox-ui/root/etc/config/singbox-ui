config inbound 'tproxy_in'
	option enabled '0'
	option mode 'constructor'
	option protocol 'tproxy'
	option listen '::'
	option listen_port '7893'
	list   interface 'br-lan'
	option hijack_dns '0'
	option nft_rules '1'

config ruleset 'geosite_cn'
	option enabled '0'
	option type 'remote'
	option url 'https://cdn.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-cn.srs'
	option format 'binary'
	option dns_fakeip '0'
	option dns_fakeip_tag 'fakeip'
	option nft_rules '0'
	option update_interval '86400'

config route_rule 'cn_to_direct'
	option enabled '0'
	list ruleset 'geosite_cn'
	option action 'direct'

config route_default 'route_default'
	option action 'direct'

config log 'log'
	option enabled '1'
	option level 'info'

config cache 'cache'
	option enabled '0'
	option path '/tmp/singbox-ui-cache.db'

config dns_server 'fakeip'
	option enabled '0'
	option type 'fakeip'
	option inet4_range '198.18.0.0/15'
	option inet6_range 'fc00::/18'

config dns_server 'out_dns'
	option enabled '0'
	option type 'https'
	option server 'dns.google'
	option server_port '443'
	option path '/dns-query'
	option detour 'direct'

config dns 'dns'
	option strategy ''
