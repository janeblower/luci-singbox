#!/bin/sh
# rpcd handler for singbox-ui. Methods:
#   generate            run /usr/share/singbox-ui/generate.uc
#   nftables {action}   run /usr/share/singbox-ui/nftables.uc apply|remove
#   restart             restart /etc/init.d/singbox-ui (full service restart)
#   refresh {what}      run subscription.uc refresh subscriptions|rulesets|all force
#   status              return JSON: { running, subscriptions[], rulesets[] }
#   read_config         return JSON: { content: <stringified /tmp/singbox-ui.json> }
#
# Env overrides (used by tests):
#   NFTABLES_CMD GENERATE_UC SINGBOX_INIT REFRESH_SH SINGBOX_TMP SINGBOX_CONFIG

NFTABLES_CMD=${NFTABLES_CMD:-"ucode /usr/share/singbox-ui/nftables.uc"}
GENERATE_UC=${GENERATE_UC:-/usr/share/singbox-ui/generate.uc}
SINGBOX_INIT=${SINGBOX_INIT:-/etc/init.d/singbox-ui}
REFRESH_SH=${REFRESH_SH:-/usr/share/singbox-ui/subscription.uc}
TMPDIR=${SINGBOX_TMP:-/tmp/singbox-ui}
CONFIG_JSON=${SINGBOX_CONFIG:-/tmp/singbox-ui.json}

emit_list() {
	cat <<'EOF'
{
	"generate": {},
	"nftables": { "action": "string" },
	"restart": {},
	"refresh": { "what": "string" },
	"status": {},
	"read_config": {}
}
EOF
}

emit_ok() {
	printf '{"status":"ok"}\n'
}

emit_err() {
	msg=$(printf '%s' "$1" | sed -e 's/\\/\\\\/g' -e 's/"/\\"/g')
	printf '{"status":"error","message":"%s"}\n' "$msg"
}

read_field() {
	field="$1"
	if command -v jq >/dev/null 2>&1; then
		jq -r --arg f "$field" '.[$f] // empty'
	else
		grep -oE "\"$field\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" \
			| sed -E 's/.*"([^"]*)"$/\1/' \
			| head -n1
	fi
}

emit_status() {
	if pgrep -f 'sing-box run' >/dev/null 2>&1; then
		running='true'
	else
		running='false'
	fi

	subs='[]'
	rs='[]'
	if [ -d "$TMPDIR" ] && command -v jq >/dev/null 2>&1; then
		subs=$(
			for f in "$TMPDIR"/sub_*.txt; do
				[ -f "$f" ] || continue
				name=$(basename "$f" .txt); name=${name#sub_}
				mt=$(stat -c %Y "$f" 2>/dev/null || echo 0)
				printf '{"name":"%s","mtime":%s}\n' "$name" "$mt"
			done | jq -s '.'
		)
		rs=$(
			for f in "$TMPDIR"/rs_*.json; do
				[ -f "$f" ] || continue
				name=$(basename "$f" .json); name=${name#rs_}
				mt=$(stat -c %Y "$f" 2>/dev/null || echo 0)
				printf '{"name":"%s","mtime":%s}\n' "$name" "$mt"
			done | jq -s '.'
		)
		[ -z "$subs" ] && subs='[]'
		[ -z "$rs" ]   && rs='[]'
	fi

	printf '{"status":"ok","running":%s,"subscriptions":%s,"rulesets":%s}\n' \
		"$running" "$subs" "$rs"
}

emit_read_config() {
	if [ ! -f "$CONFIG_JSON" ]; then
		emit_err "config not generated yet"
		return
	fi
	if command -v jq >/dev/null 2>&1; then
		jq -Rs --arg s "ok" '{status:$s, content: .}' < "$CONFIG_JSON"
	else
		esc=$(sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' "$CONFIG_JSON" | awk '{printf "%s\\n", $0}')
		printf '{"status":"ok","content":"%s"}\n' "$esc"
	fi
}

case "${1:-}" in
list)
	emit_list
	;;
call)
	method="${2:-}"
	case "$method" in
	generate)
		cat >/dev/null
		if ucode "$GENERATE_UC" >/dev/null; then
			emit_ok
		else
			emit_err "generate.uc failed"
		fi
		;;
	nftables)
		action=$(read_field action)
		case "$action" in
		apply|remove)
			# NFTABLES_CMD is intentionally unquoted so the default
			# "ucode <path>" splits into argv[0]=ucode, argv[1]=<path>.
			# Tests inject a single executable path; word-split still
			# produces a valid argv.
			# shellcheck disable=SC2086
			if $NFTABLES_CMD "$action" >/dev/null; then
				emit_ok
			else
				emit_err "nftables $action failed"
			fi
			;;
		*)
			emit_err "invalid action: ${action:-<missing>}"
			;;
		esac
		;;
	restart)
		cat >/dev/null
		if "$SINGBOX_INIT" restart >/dev/null 2>&1; then
			emit_ok
		else
			emit_err "service restart failed"
		fi
		;;
	refresh)
		what=$(read_field what)
		case "$what" in
		subscriptions|rulesets|all|"") ;;
		*) emit_err "invalid what: $what"; exit 0 ;;
		esac
		[ -z "$what" ] && what=all
		if ucode "$REFRESH_SH" refresh "$what" force >/dev/null 2>&1; then
			emit_ok
		else
			emit_err "refresh $what failed"
		fi
		;;
	status)
		cat >/dev/null
		emit_status
		;;
	read_config)
		cat >/dev/null
		emit_read_config
		;;
	*)
		emit_err "unknown method: $method"
		;;
	esac
	;;
*)
	echo "Usage: $0 {list|call <method>}" >&2
	exit 1
	;;
esac
