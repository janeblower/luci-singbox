#!/usr/bin/ucode -L/usr/share/singbox-ui/lib
// rpcd handler for singbox-ui. Methods:
//   generate            run /usr/share/singbox-ui/generate.uc
//   nftables {action}   run /usr/share/singbox-ui/nftables.uc apply|remove
//   restart             restart /etc/init.d/singbox-ui (full service restart)
//   refresh {what}      run subscription.uc refresh subscriptions|rulesets|all force
//   status              return JSON: { running, subscriptions[], rulesets[] }
//   read_config         return JSON: { content: <stringified /tmp/singbox-ui.json> }
//   clash_get           proxy GET request to Clash API (read-side, read ACL)
//   clash_mutate        proxy POST/PATCH/PUT/DELETE to Clash API (write ACL)
//   export_section      return sing-box JSON for ONE inbound/outbound section
//   preview_config      dry-run: generate full config to a tmpfile, return body
//
// Env overrides (used by tests):
//   NFTABLES_CMD GENERATE_UC SINGBOX_INIT SUBSCRIPTION_UC SINGBOX_TMP SINGBOX_CONFIG
//   EXPORT_SECTION_UC CLASH_CURL CLASH_LISTEN CLASH_PORT CLASH_SECRET UCI_CONFIG_DIR
//   SINGBOX_VARLIB

'use strict';

let fs = require("fs");

const NFTABLES_CMD = getenv("NFTABLES_CMD") || "ucode -L /usr/share/singbox-ui/lib /usr/share/singbox-ui/nftables.uc";
const GENERATE_UC  = getenv("GENERATE_UC")  || "/usr/share/singbox-ui/generate.uc";
const SINGBOX_INIT = getenv("SINGBOX_INIT") || "/etc/init.d/singbox-ui";
const SUBSCRIPTION_UC = getenv("SUBSCRIPTION_UC") || "/usr/share/singbox-ui/subscription.uc";
const EXPORT_SECTION_UC = getenv("EXPORT_SECTION_UC") || "/usr/share/singbox-ui/export_section.uc";
const UCODE_LIB    = getenv("UCODE_LIB")    || "/usr/share/singbox-ui/lib";
const TMPDIR       = getenv("SINGBOX_TMP")  || "/tmp/singbox-ui";
const CONFIG_JSON  = getenv("SINGBOX_CONFIG") || "/tmp/singbox-ui.json";
const CLASH_CURL   = getenv("CLASH_CURL")   || "curl";
const VARLIB       = getenv("SINGBOX_VARLIB") || "/var/lib/singbox-ui";
// bbolt-client helper: not packaged in the .apk; fetched on demand from the
// fixed `bbolt-latest` GitHub Release and installed here. Test-overridable.
const BBOLT_PATH   = getenv("SINGBOX_BBOLT_BIN") || "/usr/libexec/singbox-ui/bbolt-client";
const BBOLT_BASE   = getenv("BBOLT_RELEASE_BASE")
	|| "https://github.com/janeblower/luci-singbox/releases/download/bbolt-latest";

function emit(obj) { printf("%J\n", obj); }
function emit_ok()        { emit({ status: "ok" }); }
function emit_err(msg)    { emit({ status: "error", message: msg }); }

function drain_stdin() {
	try { fs.stdin.read("all"); } catch (e) {}
}

function parse_args() {
	let raw = "";
	try { raw = fs.stdin.read("all") || ""; } catch (e) { raw = ""; }
	if (!length(raw)) return {};
	try {
		let v = json(raw);
		return (type(v) === "object") ? v : {};
	} catch (e) { return {}; }
}

// sq(s) — single-quote escape for /bin/sh.
function sq(s) { return "'" + replace(s, "'", "'\\''") + "'"; }

// valid_section_name(name) — контракт имени UCI-секции, общий для
// export_section: непустая строка ≤64 символов,
// ^[A-Za-z0-9_-]+$. Чистый предикат (bool), ничего не печатает — emit остаётся
// на call-site, чтобы сохранить разные сообщения об ошибке.
function valid_section_name(name) {
	return type(name) === "string" && length(name) >= 1 && length(name) <= 64
		&& match(name, /^[A-Za-z0-9_-]+$/);
}

// run(cmd, ...extra) — cmd is either an argv array or a shell-style string
// (whitespace-split into argv). We always execute through /bin/sh so we can
// redirect child stdout/stderr away from our own — anything the child prints
// would otherwise corrupt the JSON response we emit to rpcd.
function run(cmd, ...extra) {
	let argv = (type(cmd) === "array") ? [...cmd] : split(cmd, " ");
	for (let a in extra) push(argv, a);
	let quoted = [];
	for (let a in argv) push(quoted, sq(a));
	let shcmd = join(" ", quoted) + " >/dev/null 2>&1";
	return system(shcmd) === 0;
}

// run_env(argv, env_map) — like run() but prefixes the shell line with one
// or more `VAR=VALUE` assignments. Both keys and values are single-quoted via
// sq() so callers may pass arbitrary paths (with spaces / quotes) as values.
// The shell parses leading assignments as the env for the next command; we
// keep the same stdout/stderr redirection as run() so a chatty child can't
// corrupt our JSON response.
function run_env(cmd, env_map) {
	let argv = (type(cmd) === "array") ? [...cmd] : split(cmd, " ");
	let quoted = [];
	if (type(env_map) === "object") {
		for (let k, v in env_map) push(quoted, k + "=" + sq(v));
	}
	for (let a in argv) push(quoted, sq(a));
	let shcmd = join(" ", quoted) + " >/dev/null 2>&1";
	return system(shcmd) === 0;
}

// run_capture(argv) — like run() but returns child stdout (string) or null.
// stderr is discarded so it can't corrupt the captured body.
function run_capture(argv) {
	let quoted = [];
	for (let a in argv) push(quoted, sq(a));
	let p = fs.popen(join(" ", quoted) + " 2>/dev/null", "r");
	if (!p) return null;
	let out = p.read("all") ?? "";
	p.close();
	return out;
}

// uc_argv(script, ...rest) — argv для запуска bundled-.uc через системный
// ucode с app-lib на module-path. rest — варарг-массив, for...in идёт по
// значениям (тот же приём, что run(cmd, ...extra) выше).
function uc_argv(script, ...rest) {
	let a = ["ucode", "-L", UCODE_LIB, script];
	for (let r in rest) push(a, r);
	return a;
}

// is_singbox_running() — query procd via ubus first; fall back to
// `pgrep -x sing-box` (basename-only match) if ubus is unavailable.
// Avoids false positives on shells/processes whose commandline merely
// contains the string "sing-box run" (e.g. the old `pgrep -f` form).
function is_singbox_running() {
	// Try procd ubus first. `service list {name:"singbox-ui"}` returns
	// {"singbox-ui":{"instances":{...}}} where each instance has `running`.
	let body = run_capture(["ubus", "call", "service", "list",
	                        "{\"name\":\"singbox-ui\"}"]);
	if (body != null && length(body)) {
		let j;
		try { j = json(body); } catch (_) { j = null; }
		if (type(j) === "object" && type(j["singbox-ui"]) === "object") {
			let instances = j["singbox-ui"].instances;
			if (type(instances) === "object") {
				for (let _name, inst in instances) {
					if (inst.running === true) return true;
				}
			}
		}
	}
	// Fallback: `pgrep -x sing-box` matches the basename only (no false
	// positives on shells containing "sing-box run").
	return run(["pgrep", "-x", "sing-box"]);
}

function list_files_with_mtime(dir, prefix, suffix) {
	let out = [];
	let entries;
	try { entries = fs.lsdir(dir); } catch (e) { return out; }
	if (!entries) return out;
	let plen = length(prefix), slen = length(suffix);
	for (let name in entries) {
		if (substr(name, 0, plen) !== prefix) continue;
		if (substr(name, -slen) !== suffix) continue;
		let st;
		try { st = fs.stat(`${dir}/${name}`); } catch (e) { continue; }
		if (!st || st.type !== "file") continue;
		let bare = substr(name, plen, length(name) - plen - slen);
		push(out, { name: bare, mtime: st.mtime });
	}
	return out;
}

function call_generate() {
	drain_stdin();
	if (run(uc_argv(GENERATE_UC))) emit_ok();
	else {
		try { require("log").log_event("error", "rpc.generate.failed", {}); } catch (_) {}
		emit_err("generate.uc failed");
	}
}

function call_nftables() {
	let args = parse_args();
	let action = args.action || "";
	if (action !== "apply" && action !== "remove") {
		emit_err("invalid action: " + (length(action) ? action : "<missing>"));
		return;
	}
	if (run(NFTABLES_CMD, action)) emit_ok();
	else emit_err(`nftables ${action} failed`);
}

function call_restart() {
	drain_stdin();
	if (run([SINGBOX_INIT, "restart"])) emit_ok();
	else emit_err("service restart failed");
}

function call_refresh() {
	let args = parse_args();
	let what = args.what || "all";
	if (what !== "subscriptions" && what !== "rulesets" && what !== "all") {
		emit_err(`invalid what: ${what}`);
		return;
	}
	if (run(uc_argv(SUBSCRIPTION_UC, "refresh", what, "force"))) emit_ok();
	else emit_err(`refresh ${what} failed`);
}

function call_status() {
	drain_stdin();
	let subs = list_files_with_mtime(TMPDIR, "sub_", ".txt");
	let rs   = list_files_with_mtime(TMPDIR, "rs_",  ".json");
	emit({
		status:        "ok",
		now:           time(),
		running:       is_singbox_running(),
		subscriptions: subs,
		rulesets:      rs
	});
}

// cached_pkg_version() — версия пакета для status_detail. rpcd форкает свежий
// обработчик на каждый вызов, поэтому in-memory кэш не выживает: персистим на
// диск под VARLIB и форкаем apk только при cache-miss. OpenWrt 25.12.3 — apk
// (не opkg); `apk list --installed <pkg>` читает локальную installed-БД (без
// сети) и печатает строку вида
//   "luci-singbox-ui-0.0.0-r337 noarch {luci-singbox-ui} (...) [installed]"
// Версия = первый токен со снятым префиксом имени. (НЕ переиспользовать старый
// opkg-парсер split(line," - ") — в apk нет поля " - ".)
// audit 13.2: ЭТОТ парсер обязан давать тот же результат, что и sed в
// etc/init.d/singbox-ui::start_service (прогрев того же кэша pkg_version).
// Меняешь один — синхронь другой; test_status_detail.sh проверяет
// byte-identical вывод обоих путей на одной фикстурной строке apk.
function cached_pkg_version() {
	let pkg_cache = `${VARLIB}/pkg_version`;
	let pkg_ver = "unknown";
	try {
		let f = fs.open(pkg_cache, "r");
		if (f) { pkg_ver = trim(f.read("all") || "") || "unknown"; f.close(); }
	} catch (_) {}
	if (pkg_ver !== "unknown" && length(pkg_ver)) return pkg_ver;

	const PKG = "luci-singbox-ui";
	try {
		let line = trim(run_capture(["apk", "list", "--installed", PKG]) ?? "");
		if (length(line)) {
			let tok = split(trim(split(line, "\n")[0]), " ")[0];
			let prefix = PKG + "-";
			if (substr(tok, 0, length(prefix)) === prefix)
				pkg_ver = substr(tok, length(prefix));
		}
	} catch (_) {}

	if (pkg_ver !== "unknown" && length(pkg_ver)) {
		try {
			system("mkdir -p " + sq(VARLIB) + " >/dev/null 2>&1");
			let w = fs.open(pkg_cache, "w");
			if (w) { w.write(pkg_ver); w.close(); }
		} catch (_) {}
	}
	return pkg_ver;
}

// read_json_file(path) — parse a JSON object file, returning {} on missing
// file, read error, or parse failure. Defined before its sole caller
// (call_status_detail) per the callee-precedes-caller rule.
function read_json_file(path) {
	let obj = {};
	try {
		let f = fs.open(path, "r");
		if (f) { obj = json(f.read("all") || "{}") || {}; f.close(); }
	} catch (_) {}
	return obj;
}

// status_detail — aggregate diagnostic snapshot for the Monitoring tab.
// Returns running flag, last_generate_ts, last_apply_result, config_hash
// (from generate.uc state file), schema_version (uci _meta), package_version
// (apk list --installed), service_start_ts (from init.d state file), and the
// current 'now' timestamp. All side-effect-free, safe for read ACL.
function call_status_detail() {
	drain_stdin();
	let running = is_singbox_running();

	let last_state  = read_json_file(`${VARLIB}/last_state.json`);
	let apply_state = read_json_file(`${VARLIB}/apply_state.json`);
	let svc_state   = read_json_file(`${VARLIB}/service_state.json`);

	let schema = 0;
	try {
		let s = run_capture(["uci", "-q", "get", "singbox-ui._meta.schema_version"]) ?? "";
		schema = +trim(s) || 0;
	} catch (_) {}

	let pkg_ver = cached_pkg_version();

	emit({
		status: "ok",
		running: running,
		last_generate_ts: last_state.last_generate_ts || 0,
		// S1.1: last_generate_result = config was written; last_apply_result =
		// sing-box accepted + procd started it (written by init.d, not generate).
		last_generate_result: last_state.last_generate_result || "unknown",
		last_apply_result: apply_state.last_apply_result || "unknown",
		last_apply_ts: apply_state.last_apply_ts || 0,
		config_hash: last_state.config_hash || "unknown",
		schema_version: schema,
		package_version: pkg_ver,
		service_start_ts: svc_state.service_start_ts || 0,
		now: time(),
	});
}

function call_protocol_schema() {
    let dump;
    try { dump = require("protocols.schema_dump"); }
    catch (e) { emit_err("require(protocols.schema_dump) failed"); return; }
    // Ensure all descriptors are eager-loaded into the registry.
    try { require("outbound"); require("inbound"); }
    catch (e) { emit_err("registry load failed"); return; }
    emit({ status: "ok", version: 1, schema: dump.dump_all() });
}

function call_read_config() {
	drain_stdin();
	let fd = fs.open(CONFIG_JSON, "r");
	if (!fd) { emit_err("config not generated yet"); return; }
	let content = fd.read("all") || "";
	fd.close();

	// Phase E1: scrub removed — read_config returns plain JSON.
	let obj;
	try { obj = json(content); }
	catch (e) { emit_err("config not valid JSON"); return; }

	emit({ status: "ok", content: sprintf("%.4J", obj) });
}

// clash_safe_listen(v) — sanitise a Clash listen host before it is interpolated
// into the curl URL (audit 6.3). Accepts a dotted-quad / bracket-less IPv6 /
// hostname charset only — no '@', '/', '?', '#', ':' or whitespace, so a crafted
// value like "evil.com/x?" or "host@attacker" cannot reshape the URL into an
// SSRF/exfil target. Returns the value unchanged when safe, else null. (IPv6
// literals carry ':' and are intentionally rejected here — the loopback default
// covers the only address the UI ever talks to.)
function clash_safe_listen(v) {
	if (type(v) !== "string" || !length(v) || length(v) > 255) return null;
	if (!match(v, /^[A-Za-z0-9._-]+$/)) return null;
	return v;
}

// clash_safe_port(p) — port must be numeric 1..65535 (audit 6.3). Mirrors
// nftables.uc::validate_port. Returns the canonical string form or null.
function clash_safe_port(p) {
	if (p == null || p === "") return null;
	let n = (type(p) === "int") ? p : +p;
	if (type(n) !== "int" || n < 1 || n > 65535) return null;
	return sprintf("%d", n);
}

// clash_params() — env overrides (tests) win, else read the clash_api UCI section.
// listen/port are validated (audit 6.3) and fall back to loopback defaults on a
// crafted/invalid value so a bad UCI write can never redirect the curl request.
function clash_params() {
	let listen = getenv("CLASH_LISTEN");
	let port   = getenv("CLASH_PORT");
	let secret = getenv("CLASH_SECRET");
	if (listen == null || port == null || secret == null) {
		let s = {};
		try { s = require("uci").cursor().get_all("singbox-ui", "clash_api") ?? {}; } catch (e) {}
		if (listen == null) listen = (s.listen != null && length(s.listen)) ? s.listen : "127.0.0.1";
		if (port   == null) port   = (s.port   != null && length(s.port))   ? s.port   : "9090";
		if (secret == null) secret = s.secret ?? "";
	}
	listen = clash_safe_listen(listen) ?? "127.0.0.1";
	port   = clash_safe_port(port)     ?? "9090";
	return { listen: listen, port: port, secret: secret };
}

// export_section(kind, name) — pure read of a single inbound/outbound UCI
// section, dispatched through the shared lib builder. The actual JSON shape
// comes from export_section.uc (which has access to lib/ via -L); we just
// forward its stdout verbatim. No side effects: no file writes, no service
// restart, no nftables touch.
function call_export_section() {
	let args = parse_args();
	let kind = args.kind || "";
	let name = args.name || "";
	if (kind !== "inbound" && kind !== "outbound") {
		emit_err("invalid kind: " + (length(kind) ? kind : "<missing>"));
		return;
	}
	// UCI section name contract (S1-3): a UCI section name must be
	// a non-empty ^[A-Za-z0-9_-]+$ string of at most 64 chars — defense-in-depth
	// against injection/traversal (shared predicate valid_section_name).
	if (!valid_section_name(name)) {
		emit_err("invalid or missing name");
		return;
	}
	// Phase E1: no REVEAL_TOKEN — scrubbing removed. run_capture builds the
	// identical `… 2>/dev/null` shell line and returns stdout (null only on
	// popen failure), so behaviour matches the previous inline form.
	let body = run_capture(uc_argv(EXPORT_SECTION_UC, kind, name));
	if (body == null) { emit_err("export_section helper failed"); return; }
	// export_section.uc always emits a single JSON line ({status,...}) — pass
	// through verbatim so the section object stays a proper JSON value (not
	// a re-stringified payload).
	let trimmed = trim(body);
	if (!length(trimmed)) { emit_err("export_section helper produced no output"); return; }
	print(trimmed + "\n");
}

// preview_tmp() — atomic tmpfile creation via mktemp(1). mktemp uses
// O_EXCL under the hood, so there is no symlink race (cf. the previous
// time+urandom path form, which used fs.open(..., "w") that truncates
// without O_EXCL). Returns the absolute path or null on failure.
function preview_tmp() {
	let path = run_capture(["mktemp", "-p", "/tmp",
	                        "singbox-ui-preview.XXXXXX"]);
	if (path == null) return null;
	// mktemp prints the path with a trailing newline.
	let trimmed = trim(path);
	if (!length(trimmed)) return null;
	return trimmed;
}

// preview_config — dry-run flavour of `generate`. Runs generate.uc with
// SINGBOX_CONFIG pointed at a per-time/per-random tmpfile (so concurrent
// calls don't collide), reads the emitted JSON, removes the tmpfile, and
// returns the body. No writes outside the tmpfile, no nftables, no service
// restart.
//
// Cleanup is unconditional: if generate.uc fails we still try to remove the
// tmpfile before returning the error, so a partial write never lingers on
// disk.
function call_preview_config() {
	drain_stdin();
	// Phase E1: scrub removed — preview returns plain JSON.
	let tmp = preview_tmp();
	if (tmp == null) { emit_err("cannot create preview tmpfile"); return; }
	let ok = run_env(uc_argv(GENERATE_UC), { SINGBOX_CONFIG: tmp });
	if (!ok) {
		try { fs.unlink(tmp); } catch (_) {}
		emit_err("preview generation failed");
		return;
	}
	let f = fs.open(tmp, "r");
	if (!f) {
		emit_err("preview tmp missing after generate");
		return;
	}
	let body = f.read("all") ?? "";
	f.close();
	try { fs.unlink(tmp); } catch (_) {}

	let obj;
	try { obj = json(body); }
	catch (e) { emit_err("preview output not valid JSON"); return; }

	// Match generate.uc:102 pretty-print indent (%.4J) so the wire format the
	// UI sees here is byte-identical to what `generate` would write to disk.
	emit({ status: "ok", content: sprintf("%.4J", obj) });
}

// clash_path_ok(path) — defense-in-depth allowlist for Clash API endpoints
// the UI is allowed to reach. The read ACL already separates clash_get from
// clash_mutate; this stops a caller from probing arbitrary Clash paths
// (e.g. future debug endpoints) by stuffing them through the proxy. Match by
// prefix so /proxies/<group>, /connections/<id>, /group/<name> still pass.
function clash_path_ok(path) {
	if (type(path) !== "string") return false;
	if (substr(path, 0, 1) !== "/") return false;
	// Reject traversal / NUL / whitespace outright. NB: the '-' MUST be last in
	// the class (literal) — ucode's regex engine mis-parses a mid-class escaped
	// hyphen like `_\-\/` as the range _..(/) and aborts with "Invalid character
	// range". Same char set as before: word chars, '_', '.', '/', '-'.
	if (!match(path, /^\/[A-Za-z0-9_.\/-]*$/)) return false;
	if (index(path, "..") >= 0) return false;
	let allow = [ "/version", "/configs", "/connections", "/traffic",
	              "/proxies", "/group", "/providers" ];
	for (let pfx in allow) {
		if (path === pfx) return true;
		if (substr(path, 0, length(pfx) + 1) === pfx + "/") return true;
	}
	return false;
}

// clash_header_tmp(secret) — write `Authorization: Bearer <secret>` to a 0600
// mktemp file so the secret never appears in curl's argv / the process table
// (audit 6.2). curl reads it via `-H @<file>`. Returns the path or null; the
// caller MUST unlink it unconditionally after the curl call (mirrors
// preview_config's tmpfile cleanup). umask 0177 forces 0600 on the freshly
// created file even before we write it.
function clash_header_tmp(secret) {
	let path = run_capture(["sh", "-c",
	    "umask 0177 && mktemp -p /tmp singbox-ui-clash-hdr.XXXXXX"]);
	if (path == null) return null;
	let trimmed = trim(path);
	if (!length(trimmed)) return null;
	let f;
	try { f = fs.open(trimmed, "w"); } catch (_) { f = null; }
	if (!f) { try { fs.unlink(trimmed); } catch (_) {} return null; }
	// Defense-in-depth: curl's `-H @file` treats every line as a separate header,
	// so a CR/LF in the secret would inject extra headers. Strip them so the
	// Authorization line is always single-line (audit 6.2 hardening).
	let safe = replace(`${secret}`, /[\r\n]/g, "");
	f.write(`Authorization: Bearer ${safe}\n`);
	f.close();
	return trimmed;
}

// clash_proxy(method, path, body) — shared low-level curl proxy. Inputs MUST
// be pre-validated by the caller: `method` is one of the HTTP verbs accepted
// by Clash, `path` starts with '/', and `body` is either null or a string.
// Reads Clash listen/port/secret from env (test override) or UCI.
function clash_proxy(method, path, body) {
	let p = clash_params();
	let url = `http://${p.listen}:${p.port}${path}`;
	// audit 6.2: the bearer secret goes through a 0600 tmpfile (`-H @file`), not
	// argv, so a co-located unprivileged user can't read it from /proc/<pid>/cmdline.
	let hdr = clash_header_tmp(p.secret);
	if (hdr == null) { emit_err("clash request failed (header tmpfile)"); return; }
	let argv = [ CLASH_CURL, "-s", "-m", "5", "-X", method,
	             "-H", `@${hdr}`, url ];
	if (body != null && length(body)) { push(argv, "--data"); push(argv, body); }
	let resp = run_capture(argv);
	// Unlink unconditionally (success or popen failure) so the secret never
	// lingers on disk — same discipline as call_preview_config's tmpfile.
	try { fs.unlink(hdr); } catch (_) {}
	if (resp == null) { emit_err("clash request failed"); return; }
	emit({ status: "ok", body: resp });
}

// clash_get — GET only. Refuses any caller-supplied `method` field so a
// caller restricted to the read ACL cannot upgrade to a write verb by
// stuffing { method: "PATCH" } into the args (spec C1.2).
function call_clash_get() {
	let args = parse_args();
	if (args.method != null) {
		emit_err("clash_get does not accept method; use clash_mutate");
		return;
	}
	let path = args.path || "";
	if (!clash_path_ok(path)) { emit_err("invalid path"); return; }
	clash_proxy("GET", path, null);
}

// clash_mutate — POST/PATCH/PUT/DELETE only. GET is refused so writes are
// only reachable through the write ACL. PATCH covers `/configs` (mode
// switch), PUT covers `/proxies/<group>` selector, DELETE covers
// `/connections` close-all, POST covers misc actions.
function call_clash_mutate() {
	let args = parse_args();
	let method = args.method;
	if (method !== "POST" && method !== "PATCH"
	    && method !== "PUT" && method !== "DELETE") {
		emit_err("clash_mutate requires method in {POST,PATCH,PUT,DELETE}");
		return;
	}
	let path = args.path || "";
	if (!clash_path_ok(path)) { emit_err("invalid path"); return; }
	// audit 6.4: rpcd sigs are advisory, so guard `body` here. clash_proxy uses
	// length(body) to decide whether to attach --data; a non-string (object/number)
	// would be truthy under length() and get pushed into argv as a non-string token,
	// stringified in an undefined way. null / "" stay valid (no --data, unchanged).
	if (args.body != null && type(args.body) !== "string") {
		emit_err("body must be a string");
		return;
	}
	clash_proxy(method, path, args.body);
}

// host_arch() → bbolt asset arch ("x86_64"|"aarch64"|"armv7"|"mipsel"|"mips") or
// null. Prefers `apk --print-arch` (distinguishes mips endianness, which uname -m
// cannot — both report "mips"); falls back to uname -m for x86_64/aarch64.
function host_arch() {
	let pa = trim(run_capture(["apk", "--print-arch"]) ?? "");
	if (length(pa)) {
		// apk --print-arch is authoritative on OpenWrt: map it or return null.
		// Do NOT fall through to uname -m, or an unsupported apk arch (mips64,
		// riscv64, …) would be masked by the host's uname (e.g. x86_64 in CI).
		if (substr(pa, 0, 6) === "x86_64") return "x86_64";
		if (substr(pa, 0, 7) === "aarch64") return "aarch64";
		if (substr(pa, 0, 6) === "mips64") return null;       // 64-bit mips unsupported
		if (substr(pa, 0, 6) === "mipsel") return "mipsel";   // before "mips"
		if (substr(pa, 0, 4) === "mips") return "mips";
		if (substr(pa, 0, 5) === "armeb") return null;        // big-endian ARM unsupported
		if (substr(pa, 0, 3) === "arm") return "armv7";
		return null;                                          // definitive but unsupported
	}
	// Fallback only when apk is unavailable: uname -m (64-bit arches only)
	let m = trim(run_capture(["uname", "-m"]) ?? "");
	if (m === "x86_64" || m === "amd64") return "x86_64";
	if (m === "aarch64" || m === "arm64") return "aarch64";
	if (substr(m, 0, 5) === "armv7" || m === "armv7l") return "armv7";
	return null;
}

// bbolt_status — read-only: is the helper installed, for which arch, where.
// `version` is the binary mtime (the static reader prints no version string),
// enough for the UI to tell "freshly (re)installed" apart. No side effects.
function call_bbolt_status() {
	drain_stdin();
	let st = fs.stat(BBOLT_PATH);
	let installed = (st && st.type === "file") ? true : false;
	emit({
		status:    "ok",
		installed: installed,
		arch:      host_arch() ?? "",
		path:      BBOLT_PATH,
		version:   installed ? sprintf("%d", st.mtime) : "",
	});
}

// bbolt_install — download the arch-matched bbolt-client-rs-<arch> from the
// latest GitHub Release plus sha256sums.txt, verify the checksum, and install
// 0755 to BBOLT_PATH via an atomic rename. Every failure (unknown arch, network,
// missing/!matching sha) returns an error and installs nothing.
function call_bbolt_install() {
	drain_stdin();
	let arch = host_arch();
	if (arch == null) { emit_err("unsupported arch (need x86_64/aarch64/armv7/mipsel/mips)"); return; }
	let asset = `bbolt-client-rs-${arch}`;

	// Install dir = parent of BBOLT_PATH (derived, not hardcoded, so a test
	// override lands in its sandbox). Download the binary INTO this dir so the
	// final rename is same-filesystem (atomic). A /tmp → /usr/libexec rename is
	// cross-device on OpenWrt (tmpfs vs overlay) and fails with EXDEV.
	let i = length(BBOLT_PATH) - 1;
	while (i >= 0 && substr(BBOLT_PATH, i, 1) !== "/") i--;
	let parent = (i > 0) ? substr(BBOLT_PATH, 0, i) : "/";
	system("mkdir -p " + sq(parent) + " >/dev/null 2>&1");

	let bin_tmp  = `${parent}/.bbolt-client.dl`;
	let sums_tmp = "/tmp/bbolt-client.sha256sums";

	if (!run(["curl", "-sfL", "-o", bin_tmp,  `${BBOLT_BASE}/${asset}`])) {
		try { fs.unlink(bin_tmp); } catch (_) {}
		emit_err("download failed (binary)"); return;
	}
	if (!run(["curl", "-sfL", "-o", sums_tmp, `${BBOLT_BASE}/sha256sums.txt`])) {
		try { fs.unlink(bin_tmp); } catch (_) {}
		emit_err("download failed (sha256sums.txt)"); return;
	}

	// Expected sha for our asset: a "<hash>␠␠<name>" line in sha256sums.txt.
	let want = "";
	let sf = fs.open(sums_tmp, "r");
	if (sf) {
		for (let line in split(sf.read("all") ?? "", "\n")) {
			let parts = split(trim(line), /[ \t]+/);
			if (length(parts) >= 2 && parts[length(parts) - 1] === asset) {
				want = parts[0]; break;
			}
		}
		sf.close();
	}
	try { fs.unlink(sums_tmp); } catch (_) {}
	if (!length(want)) { try { fs.unlink(bin_tmp); } catch (_) {} emit_err("no sha256 for asset"); return; }

	let got = "";
	let h = run_capture(["sha256sum", bin_tmp]);
	if (h != null) got = split(trim(h), /[ \t]+/)[0];
	if (lc(got) !== lc(want)) {
		try { fs.unlink(bin_tmp); } catch (_) {}
		emit_err("sha256 mismatch — refusing to install"); return;
	}

	system("chmod 0755 " + sq(bin_tmp) + " >/dev/null 2>&1");
	let ok = false;
	try { ok = fs.rename(bin_tmp, BBOLT_PATH); } catch (_) { ok = false; }
	if (!ok) { try { fs.unlink(bin_tmp); } catch (_) {} emit_err("install (rename) failed"); return; }
	emit({ status: "ok", installed: true, arch: arch, path: BBOLT_PATH });
}

// METHODS — единый источник правды: имя метода → { sig, handler }. `sig`
// уходит в emit_list() (rpcd читает сигнатуры), `handler` — в диспетчер.
// Порядок ключей load-bearing: %J сохраняет порядок вставки (проверено на
// целевом ucode), поэтому вывод list() байт-идентичен прежнему хардкоду.
// Read/write-класс НЕ здесь — он в ACL-файле (acl.d), сторожится
// tests/test_acl_coverage.sh + tests/test_rpcd_acl_sync.sh.
const METHODS = {
	generate:            { sig: {},                                                   handler: call_generate },
	nftables:            { sig: { action: "string" },                                 handler: call_nftables },
	restart:             { sig: {},                                                   handler: call_restart },
	refresh:             { sig: { what: "string" },                                   handler: call_refresh },
	status:              { sig: {},                                                   handler: call_status },
	status_detail:       { sig: {},                                                   handler: call_status_detail },
	read_config:         { sig: {},                                                   handler: call_read_config },
	clash_get:           { sig: { path: "string" },                                   handler: call_clash_get },
	clash_mutate:        { sig: { method: "string", path: "string", body: "string" }, handler: call_clash_mutate },
	export_section:      { sig: { kind: "string", name: "string" },                   handler: call_export_section },
	preview_config:      { sig: {},                                                   handler: call_preview_config },
	protocol_schema:     { sig: {},                                                   handler: call_protocol_schema },
	bbolt_status:        { sig: {},                                                   handler: call_bbolt_status },
	bbolt_install:       { sig: {},                                                   handler: call_bbolt_install },
};

function emit_list() {
	let sigs = {};
	for (let name, m in METHODS) sigs[name] = m.sig;
	emit(sigs);
}

let argv   = ARGV;
let cmd    = argv[0] || "";
let method = argv[1] || "";

if (cmd === "list") {
	emit_list();
	exit(0);
}

if (cmd === "call") {
	let m = METHODS[method];
	if (m) m.handler();
	else emit_err(`unknown method: ${method}`);
	exit(0);
}

warn("Usage: singbox-ui {list|call <method>}\n");
exit(1);
