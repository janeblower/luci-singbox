{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "files": { "includes": ["tests/**/*.ts"] },
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 2 },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off"
      }
    }
  },
  "javascript": { "formatter": { "quoteStyle": "double" } }
}
