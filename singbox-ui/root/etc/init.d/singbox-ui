#!/bin/sh /etc/rc.common
# shellcheck disable=SC2034
USE_PROCD=1
START=99
STOP=01

GENERATE_UC=/usr/share/singbox-ui/generate.uc
SUBSCRIPTION_UC=/usr/share/singbox-ui/subscription.uc
RULESETS_UC=/usr/share/singbox-ui/nft-rulesets.uc
NFTABLES_UC=/usr/share/singbox-ui/nftables.uc
APPLY_PLUGINS_UC=/usr/share/singbox-ui/apply-plugins.uc
UCODE_LIB=/usr/share/singbox-ui/lib
# Overridable so tests can stub the binary (default is the packaged path used by
# the procd command below). Used for both `check` (S6.1) and `run`.
SINGBOX_BIN="${SINGBOX_BIN:-/usr/bin/sing-box}"

# --- Service-lifecycle lock (missed-1) -------------------------------------
# Every daemon-mutating path funnels through this script: boot `start`, the
# rpcd `restart` method (→ `reload`), and BOTH */15 cron jobs (subscription.uc
# and nft-rulesets.uc each shell out to `<init> reload`). Without
# serialization two stop+start cycles can interleave and leave sing-box down
# or double-started, or an nft apply can race a half-written restart. We
# serialize with an atomic mkdir lock-DIRECTORY — busybox ash has no flock and
# `>` is not exclusive, so mkdir is the atomic primitive (same approach as
# nftables.uc's apply-lock). Re-entrant within ONE process via a depth counter
# so reload_config can hold the lock across its nested stop+start. A stale
# lock (holder crashed mid-cycle) is reclaimed after LC_LOCK_TTL so it can
# never wedge boot/cron forever.
LC_LOCK_DIR=/tmp/singbox-ui/.lifecycle.lock
LC_LOCK_TTL="${SINGBOX_LIFECYCLE_TTL:-120}"

_lc_acquire() {
	_LC_DEPTH=$(( ${_LC_DEPTH:-0} + 1 ))
	[ "$_LC_DEPTH" -gt 1 ] && return 0   # already held by this process
	_LC_OWNED=0                          # becomes 1 only once WE create the dir
	mkdir -p /tmp/singbox-ui
	_lc_i=0
	while :; do
		if mkdir "$LC_LOCK_DIR" 2>/dev/null; then
			echo $$ > "$LC_LOCK_DIR/pid" 2>/dev/null
			_LC_OWNED=1
			return 0
		fi
		# Stale-lock reclaim: steal a lock dir older than the TTL, but ONLY when
		# its holder is actually gone (crashed). A live but slow holder (a long
		# stop+start past the TTL) keeps its lock instead of being stolen, which
		# would otherwise let two lifecycle cycles run concurrently.
		_lc_now=$(date +%s)
		_lc_mt=$(date -r "$LC_LOCK_DIR" +%s 2>/dev/null || echo "$_lc_now")
		if [ $(( _lc_now - _lc_mt )) -ge "$LC_LOCK_TTL" ]; then
			_lc_pid=$(cat "$LC_LOCK_DIR/pid" 2>/dev/null)
			if [ -z "$_lc_pid" ] || ! kill -0 "$_lc_pid" 2>/dev/null; then
				logger -t singbox-ui "lifecycle lock stale (holder ${_lc_pid:-?} gone) — reclaiming"
				rm -rf "$LC_LOCK_DIR" 2>/dev/null
				continue
			fi
		fi
		_lc_i=$(( _lc_i + 1 ))
		if [ "$_lc_i" -ge "$LC_LOCK_TTL" ]; then
			# Waited a full TTL without acquiring — proceed rather than wedge
			# boot/cron forever, but WITHOUT ownership (_LC_OWNED stays 0): we
			# never created the dir, so _lc_release must not delete the real
			# holder's lock.
			logger -t singbox-ui "lifecycle lock wait timed out — proceeding without the lock"
			return 0
		fi
		sleep 1
	done
}

_lc_release() {
	_LC_DEPTH=$(( ${_LC_DEPTH:-0} - 1 ))
	[ "${_LC_DEPTH:-0}" -gt 0 ] && return 0   # still held by an outer caller
	_LC_DEPTH=0
	# Only remove the lock dir if THIS process created it. A timed-out acquire
	# proceeded without ownership; deleting the dir here would destroy the real
	# holder's lock and break mutual exclusion exactly under contention.
	[ "${_LC_OWNED:-0}" = "1" ] && rm -rf "$LC_LOCK_DIR" 2>/dev/null
	_LC_OWNED=0
}

start_service() {
	_lc_acquire
	__do_start
	_ss_rc=$?
	_lc_release
	return "$_ss_rc"
}

__do_start() {
	mkdir -p /tmp/singbox-ui

	# Always try to refresh on (re)start, with short curl timeouts so boot
	# stays snappy. subscription.uc keeps prior sub_*.txt / rs_*.json files
	# untouched on failure, so generate.uc falls back to the cache.
	SINGBOX_BOOT_FETCH=1 ucode -L "$UCODE_LIB" "$SUBSCRIPTION_UC" fetch-subs &
	SINGBOX_BOOT_FETCH=1 ucode -L "$UCODE_LIB" "$RULESETS_UC" fetch &
	wait

	ucode -L "$UCODE_LIB" "$GENERATE_UC"

	# If neither a fresh download nor a cached config produced anything,
	# refuse to start; cron will re-run subscription.uc in ≤30 min and call
	# `reload`, which triggers start_service again.
	if [ ! -s /tmp/singbox-ui.json ]; then
		logger -t singbox-ui "refusing to start: no cached config and fetch failed"
		return 1
	fi

	# S6.1: validate the config semantically before handing it to procd. A
	# well-formed-but-rejected config (unknown field, dangling reference, bad
	# value) would otherwise make procd respawn sing-box in a tight loop. Refuse
	# to start instead and let cron/reload retry in ≤30 min. S1.1: record the
	# real apply outcome in apply_state.json (distinct from generate's state).
	mkdir -p /var/lib/singbox-ui
	if ! "$SINGBOX_BIN" check -c /tmp/singbox-ui.json 2>/tmp/singbox-ui.check.err; then
		logger -t singbox-ui "refusing to start: sing-box rejected config"
		logger -t singbox-ui "sing-box check: $(head -c 300 /tmp/singbox-ui.check.err 2>/dev/null)"
		echo "{\"last_apply_ts\":$(date +%s),\"last_apply_result\":\"failed\"}" \
			> /var/lib/singbox-ui/apply_state.json
		return 1
	fi

	# Defensive: if a previous start_service installed nft rules and the
	# user has since flipped every tproxy inbound to a non-tproxy protocol
	# (or disabled the section), `needed` will now return "0" — but the
	# old table would linger until the next `stop`. Only remove when nft
	# is not needed so the post-apply state always reflects the latest `needed`
	# decision. The remove is idempotent and a no-op when no table exists.
	# apply's atomic `add+delete+table` prelude self-replaces the table,
	# so we don't remove unconditionally before apply (which would leave a
	# blackhole if apply then fails).

	if [ "$(ucode -L "$UCODE_LIB" "$NFTABLES_UC" needed)" = "1" ]; then
		# G4: surface apply failures via syslog. apply's atomic
		# `add+delete+table` prelude self-replaces the table on failure,
		# so a stale table from a prior start won't linger.
		ucode -L "$UCODE_LIB" "$NFTABLES_UC" apply
		_nft_rc=$?
		[ "$_nft_rc" = 0 ] || logger -t singbox-ui "nft apply failed (rc=$_nft_rc)"
	else
		# nft not needed; clean up any stale table from a previous start.
		ucode -L "$UCODE_LIB" "$NFTABLES_UC" remove 2>/dev/null || true
	fi

	# Phase E: reconcile plugin-managed resources (e.g. AWG-WARP interfaces) before
	# the daemon starts. Idempotent; never fatal.
	ucode -L "$UCODE_LIB" "$APPLY_PLUGINS_UC" apply 2>/dev/null || \
		logger -t singbox-ui "apply-plugins apply returned non-zero"

	procd_open_instance
	# C3.6: drop to minimal capability set so sing-box runs without root.
	# We intentionally do NOT switch user/group to nobody/nogroup here —
	# that requires fixing FS-permissions on /tmp/singbox-ui.json and the
	# /tmp/singbox-ui/ subscription cache, which could break test envs.
	# Capabilities-only is a real security win without that risk.
	procd_set_param capabilities /etc/capabilities/singbox-ui.json
	procd_set_param command "$SINGBOX_BIN" run -c /tmp/singbox-ui.json
	# missed-2: explicit respawn policy. sing-box is a must-stay-up proxy and
	# the `sing-box check` gate above already prevents config-rejection respawn
	# loops, so we keep retrying indefinitely (retry=0) instead of letting
	# procd's default give up after ~5 crashes/hour and leave the tunnel down.
	# Args: <threshold-s> <cooldown-s> <retry: 0 = unlimited>.
	procd_set_param respawn 3600 5 0
	procd_close_instance

	# C3.3: record service-start timestamp for status_detail RPC. S1.1: the
	# config passed `sing-box check` above and was handed to procd, so record the
	# real apply result here — status_detail surfaces this as last_apply_result,
	# distinct from generate.uc's last_generate_result.
	mkdir -p /var/lib/singbox-ui
	echo "{\"service_start_ts\":$(date +%s)}" > /var/lib/singbox-ui/service_state.json
	echo "{\"last_apply_ts\":$(date +%s),\"last_apply_result\":\"ok\"}" \
		> /var/lib/singbox-ui/apply_state.json

	# Cache the package version once per start so status_detail (a hot read
	# RPC) doesn't fork apk on every call. Refreshed here so an upgrade +
	# restart re-derives it. (spec S5-PERF). OpenWrt 25.12.3 ships apk, not
	# opkg; `apk list --installed` prints "<name>-<version> noarch {...}".
	# Must yield the SAME cache format as cached_pkg_version() in the rpcd
	# handler (luci-singbox-ui/root/usr/libexec/rpcd/singbox-ui): the version
	# with the package-name prefix stripped. KEEP THE TWO IN SYNC — audit 13.2
	# (cross-linked); test_status_detail.sh asserts byte-identical output of
	# both paths for a fixture apk line.
	# audit 13.2: `\([^ ]*\).*` (no leading space before `.*`) captures the
	# first whitespace-delimited token even on a single-token line with no
	# trailing space — matching the rpcd split(line," ")[0] behaviour. The old
	# ` .*` form required a trailing space and would emit nothing on such a line.
	apk list --installed luci-singbox-ui 2>/dev/null \
		| sed -n 's/^luci-singbox-ui-\([^ ]*\).*/\1/p;q' \
		> /var/lib/singbox-ui/pkg_version || true
}

stop_service() {
	_lc_acquire
	# G7: nftables.uc remove prints "No such file or directory" on a
	# fresh stop (no table to delete). Symmetric with start_service
	# (line above already suppresses); keep operator logs quiet.
	ucode -L "$UCODE_LIB" "$NFTABLES_UC" remove 2>/dev/null
	ucode -L "$UCODE_LIB" "$APPLY_PLUGINS_UC" teardown 2>/dev/null || true
	_lc_release
}

reload_config() {
	# sing-box does not support signal-based config reload. Hold the
	# lifecycle lock across the WHOLE stop+start (missed-1) so a concurrent
	# reload/restart/boot cannot interleave its own stop+start in the gap.
	# The lock is re-entrant, so the nested stop/start below do not deadlock.
	_lc_acquire
	stop
	start
	_lc_release
}
