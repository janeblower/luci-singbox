#!/usr/bin/expect -f
# tests/docker/build-snapshot.expect
# Drive the OpenWrt first-boot serial console to seed the test image:
#   - set root password = admin
#   - enable password auth on dropbear
#   - apk update && apk add sing-box
#
# Caller (build-snapshot.sh) provides $env(SERIAL_SOCK) — a unix socket
# path connected to qemu's -serial chardev. After this script exits 0,
# the caller takes the qemu memory snapshot via the monitor.
#
# Total timeout: 5 minutes (boot + apk update + apk add sing-box).

set timeout 300
set serial_sock $env(SERIAL_SOCK)

# Verbose echo of everything coming off the serial line into the
# build log. When this script times out you want to see exactly what
# the guest was emitting; without log_user the build log only shows
# the failure message.
log_user 1

spawn socat - UNIX-CONNECT:$serial_sock

# OpenWrt 25.12.x stock combined-squashfs is built with procd's
# console_login on tty1 — there is no getty/login prompt.  Instead
# the kernel emits:
#     "Please press Enter to activate this console."
# and on the first <CR> drops directly into a passwordless root
# shell.  Older images used the classic `OpenWrt login: root` flow;
# keep that branch for forward/backward compatibility.
#
# Send an explicit Enter even after matching the press-Enter prompt:
# procd's console_login swallows the first byte to "activate" and
# then starts the shell; without a second <CR> there is no prompt
# to match below.
expect {
	-re "Please press Enter to activate this console\\." {
		send "\r"
		# Give procd a moment to spawn the shell, then nudge once
		# more to force the prompt onto the wire.
		sleep 1
		send "\r"
	}
	"OpenWrt login:" { send "root\r" }
	timeout { puts stderr "expect: never saw console activation prompt"; exit 2 }
}

# Wait for the root shell. After `Please press Enter` and one nudge
# we land at `#` directly. After `OpenWrt login: root` some builds
# prompt for an (empty) password before reaching `#`.
expect {
	"Password:" { send "\r"; exp_continue }
	"# "        { }
	timeout { puts stderr "expect: no shell after activation"; exit 2 }
}

# Set root password = admin. busybox passwd reads new + retype on
# separate lines.
send "passwd root\r"
expect "New password:"
send "admin\r"
expect "Retype password:"
send "admin\r"
expect "# "

# Allow password auth via dropbear (default for some 25.12 builds
# disables it; force-on to be safe).
#
# Escaping: Tcl "..." string => \\ becomes one backslash; \[ becomes a
# literal '[' (not Tcl command substitution). So `\\\[` produces the
# two-character sequence `\[`, which is what the OpenWrt shell needs to
# pass `[0]` to `uci` without bash glob-expansion. If you "fix" the
# double-slashes you will silently break this.
send "uci set dropbear.@dropbear\\\[0\\\].PasswordAuth='on'\r"
expect "# "
send "uci set dropbear.@dropbear\\\[0\\\].RootPasswordAuth='on'\r"
expect "# "
send "uci commit dropbear\r"
expect "# "
send "/etc/init.d/dropbear restart\r"
expect "# "

# Bring up DHCP on br-lan so apk can reach the OpenWrt feed via the
# qemu SLIRP NAT. The stock combined-squashfs ships br-lan as static
# 192.168.1.1/24 — there's no default route, so wget inside the guest
# returns EPERM the moment apk update tries to contact downloads.
send "uci set network.lan.proto='dhcp'\r"
expect "# "
send "uci commit network\r"
expect "# "
send "/etc/init.d/network restart\r"
expect "# "

# Wait up to 30 s for the default route to appear. SLIRP's built-in
# DHCP usually answers within 2-3 s but allow headroom for slow CI.
send "for _ in 1 2 3 4 5 6; do ip route | grep -q ^default && break; sleep 5; done; echo --route--; ip route; echo --end--\r"
expect "--end--"
expect "# "

# Sanity probe — fail loudly here rather than 50 s into apk update.
send "wget -q -O /dev/null https://downloads.openwrt.org/releases/25.12.3/targets/x86/64/sha256sums && echo NETOK || echo NETFAIL\r"
expect {
	"NETOK"    { }
	"NETFAIL"  { puts stderr "expect: guest cannot reach downloads.openwrt.org after DHCP"; exit 2 }
	timeout    { puts stderr "expect: net probe timed out"; exit 2 }
}
expect "# "

# Install sing-box from the OpenWrt apk feed so per-run tests don't pay
# the download.
send "apk update\r"
expect {
	-re "OK:.*distinct packages" { }
	"# "                          { }
	timeout { puts stderr "expect: apk update did not finish"; exit 2 }
}
expect "# "
send "apk add sing-box\r"
expect {
	-re "Installing sing-box" { exp_continue }
	-re "OK: .* MiB in"       { }
	"# "                       { }
	timeout { puts stderr "expect: apk add sing-box did not finish"; exit 2 }
}
expect "# "

# Sanity probe: sing-box is callable.
send "sing-box version\r"
expect {
	-re "sing-box version" { }
	timeout { puts stderr "expect: sing-box not installed"; exit 2 }
}
expect "# "

# Done. Caller drives savevm + quit via the monitor.
send "exit\r"
expect eof
exit 0
