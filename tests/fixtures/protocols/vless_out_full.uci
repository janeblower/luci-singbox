config outbound 'vless_out'
	option enabled '1'
	option type 'vless'
	option server '203.0.113.10'
	option server_port '443'
	option server_uuid '11111111-2222-3333-4444-555555555555'
	option network 'udp'
	option packet_encoding 'xudp'
	option tls_enabled '1'
	option tls_server_name 'cdn.example.com'
	option utls_enabled '1'
	option utls_fingerprint 'firefox'
	option reality_enabled '1'
	option reality_public_key 'pubkey'
	option reality_short_id 'abcd'
	option transport_type 'ws'
	option transport_path '/v'
	option transport_host 'cdn.example.com'
	option multiplex_enabled '1'
	option multiplex_protocol 'yamux'
	option bind_interface 'wan'
	option routing_mark '100'

config route_default 'route'
	option enabled '1'
	option final 'vless_out'
