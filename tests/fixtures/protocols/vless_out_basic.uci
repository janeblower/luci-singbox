config outbound 'vless_out'
	option enabled '1'
	option type 'vless'
	option server '203.0.113.10'
	option server_port '443'
	option server_uuid '11111111-2222-3333-4444-555555555555'
	option vless_flow 'xtls-rprx-vision'
	option network 'tcp'
	option tls_enabled '1'
	option tls_server_name 'cdn.example.com'

config route_default 'route'
	option enabled '1'
	option final 'vless_out'
