config inbound 'hy2_in'
    option enabled '1'
    option protocol 'hysteria2'
    option listen '::'
    option listen_port '443'
    option server_password 'hy2pass'
    option up_mbps '500'
    option down_mbps '500'
    option tls_certificate_path '/etc/sb/cert.pem'
    option tls_key_path '/etc/sb/key.pem'
